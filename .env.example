# ============================================================
# Autonomous SME Control Tower — Environment Configuration
# ============================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to git — it contains secrets.
# ============================================================

# --- AWS Credentials ---
# For local dev: use IAM user keys
# For production: use IAM roles (leave blank, use instance profile)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# --- Bedrock Model IDs ---
NOVA_LITE_MODEL_ID=amazon.nova-lite-v1:0
NOVA_EMBEDDINGS_MODEL_ID=amazon.nova-embed-v1:0
NOVA_ACT_MODEL_ID=amazon.nova-act-v1:0
NOVA_SONIC_MODEL_ID=amazon.nova-sonic-v1:0

# --- DynamoDB Tables (core) ---
SIGNALS_TABLE=autonomous-sme-signals
NSI_SCORES_TABLE=autonomous-sme-nsi-scores
STRATEGIES_TABLE=autonomous-sme-strategies
ACTIONS_TABLE=autonomous-sme-actions
EVALUATIONS_TABLE=autonomous-sme-evaluations
EMBEDDINGS_TABLE=autonomous-sme-embeddings
TASKS_TABLE=autonomous-sme-tasks

# --- DynamoDB Tables (commercial) ---
BUSINESSES_TABLE=autonomous-sme-businesses
BRANCHES_TABLE=autonomous-sme-branches
TRANSACTIONS_TABLE=autonomous-sme-transactions
INVENTORY_TABLE=autonomous-sme-inventory
COUNTERPARTIES_TABLE=autonomous-sme-counterparties
ALERTS_TABLE=autonomous-sme-alerts
INSIGHTS_TABLE=autonomous-sme-insights
UPLOAD_JOBS_TABLE=autonomous-sme-upload-jobs
OUTBOUND_INVOICES_TABLE=autonomous-sme-outbound-invoices

# --- DynamoDB Tables (auth) ---
USERS_TABLE=autonomous-sme-users

# --- S3 ---
DOCUMENTS_BUCKET=autonomous-sme-documents

# --- SES Email ---
# Verify this address in AWS SES console before sending
SES_SENDER_EMAIL=
SES_REGION=us-east-1

# --- JWT Authentication ---
# CRITICAL: Generate a strong secret for production:
#   openssl rand -hex 32
JWT_SECRET=change-me-in-production-use-a-long-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRY_HOURS=8

# --- Application ---
APP_NAME=Autonomous SME Control Tower
DEBUG=false

# --- CORS ---
# Add your production frontend URL (e.g. https://sme-control-tower.vercel.app)
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# --- Rate Limiting ---
RATE_LIMIT_RPM=120

# --- Payment Providers ---
# Paystack: get from Dashboard > Settings > API Keys & Webhooks
PAYSTACK_SECRET_KEY=
# Flutterwave: get from Dashboard > Settings > Webhooks
FLUTTERWAVE_SECRET_HASH=
# Stripe: get from Dashboard > Developers > API keys
STRIPE_SECRET_KEY=

# --- Subscriptions ---
SUBSCRIPTIONS_TABLE=autonomous-sme-subscriptions
